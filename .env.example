# Environment
# Use placeholder values only. Never commit real production secrets.
APP_ENV=local

# Backend / database
# `scripts/bootstrap-db.ps1` y `scripts/migrate-db.ps1` usan primero POSTGRES_*.
# `DATABASE_URL` la usa FastAPI y sirve de fallback para los scripts.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=tepic_catalog
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql://postgres:change_me@localhost:5432/tepic_catalog
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Required for remote migrations against Render Postgres.
# Keep `disable` in local and set `require` only for remote migrations.
PGSSLMODE=disable

# Auth
JWT_SECRET=change_me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Frontend
NEXT_PUBLIC_APP_NAME=Tepic Catalog
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_ENV=local
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# Storage
# Optional in early MVP if media is mocked locally.
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
